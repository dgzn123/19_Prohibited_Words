{
    "tasks": [
        {
            "type": "shell",
            "label": "CMake: configure + build",
            "command": "cmake -S . -B build && cmake --build build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "跨平台 CMake 构建任务。"
        }
    ],
    "version": "2.0.0"
}